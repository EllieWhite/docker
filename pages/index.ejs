<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
     <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="text-center flex flex-col justify-center gap-20">

        <%- include('partials/user-header') %>

    <% if (created) {%>
        <div class="bg-green-300 p-4">
            <p>Note is added</p>
        </div>
    <% } %>

    <% if (error) {%>
        <div class="bg-red-300 p-4">
            <p class="text-red-800">Something went wrong!</p>
        </div>
    <% } %>
    <h1 class="text-3xl font-bold underline">
      Hello world!
    </h1>
    <form action="/" method="POST" class="w-100 ml-auto mr-auto">
        <div  class="flex flex-col gap-2">
            <input type="text" name="title" class="border" required>
            <button type="submit" class="bg-blue-500 p-2 text-white text-xl rounded-md cursor-pointer">create</button>
        </div>
    </form>

    <aside>
        <h2 class="text-xl">Заметки:</h2>
         <% if (notes && notes.length>0) {%>
            <ul class="mt-2 w-200 mx-auto">
                <% for (let i = 0; i < notes.length; i++) { %>
                    <li class="flex justify-between items-center mt-2 border border-gray-300 rounded-md py-1">
                        <p class="p-2"><%= notes[i].title%></p>
                        <span><%= notes[i].owner%></span>
                        <% if (notes[i].owner === userEmail) { %>
                            <div class="flex gap-1">
                                <button data-type="edit" data-id="<%= notes[i].id %>" class="bg-blue-500 text-white px-4 py-2 rounded-l-md cursor-pointer">Редактировать</button>
                                <button data-type="remove" data-id="<%= notes[i].id %>" class="bg-red-500 text-white px-4 py-2 rounded-r-md cursor-pointer">х</button>
                            </div>
                        <% } %>
                    </li>
                <% } %>
            </ul>
            <% } else { %>
                <p>нет заметок</p>
            <% } %>
    </aside>

    <script src="/app.js"></script>
</body>
</html>